{
  "name": "Grid Dynamics Code Challenge Env",
  "image": "mcr.microsoft.com/devcontainers/universal:2",
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      },
      "extensions": [
        "ms-python.python",
        "vscjava.vscode-java-pack",
        "dbaeumer.vscode-eslint"
      ]
    }
  },
  "postCreateCommand": "echo 'Environment ready. You may now use the terminal to run tests.'"
}
